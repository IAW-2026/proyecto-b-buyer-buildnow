generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Buyer {
  id        String    @id @default(cuid())
  clerkId   String    @unique
  name      String?
  email     String    @unique
  phone     String?

  addresses Address[]
  cart      Cart?

  createdAt DateTime  @default(now())
}

model Address {
  id        String   @id @default(cuid())

  buyerId   String
  buyer     Buyer    @relation(fields: [buyerId], references: [id])

  street    String
  city      String
  notes     String?

  createdAt DateTime @default(now())
}

model Cart {
  id        String      @id @default(cuid())

  buyerId   String      @unique
  buyer     Buyer       @relation(fields: [buyerId], references: [id])

  items     CartItem[]

  createdAt DateTime    @default(now())
}

model CartItem {
  id          String    @id @default(cuid())

  cartId      String
  cart        Cart      @relation(fields: [cartId], references: [id])

  productId   String
  quantity    Int
  price       Decimal   @db.Decimal(10,2)

  createdAt   DateTime  @default(now())
}